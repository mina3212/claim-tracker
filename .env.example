# ── 로컬 개발용 환경변수 예시 ─────────────────────────────────
# 복사 후 .env 로 이름을 바꾸고 값을 채우세요.
# 절대 git commit 하지 마세요! (.gitignore 에 등록됨)

# 로컬 개발 자동 로그인 (없으면 Portal SSO 사용)
DEV_AUTO_LOGIN_EMAIL=makim@ajw.co.kr
DEV_AUTO_LOGIN_NAME=마김

# DB 접속 (앱 최초 업로드 후 .db-credentials 에서 확인)
# 로컬 임시 DB: docker run -d --name devpg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:15
DATABASE_URL=postgresql://postgres:dev@localhost:5432/postgres

# 서버 포트 (앱허브 기본값: 3000)
PORT=3000

# 세션 시크릿 (운영에선 앱허브가 자동 주입)
SESSION_SECRET=local-dev-secret-change-me

# ── 운영 (앱허브 자동 주입 — 아래는 직접 설정 불필요) ──────────
# PORTAL_PUBLIC_URL=http://10.10.120.21:9000
# PORTAL_INTERNAL_URL=http://10.10.120.21:9000
# APP_PUBLIC_URL=http://10.10.120.21:9000/apps/qm/마김/claim-tracker
# OAUTH_CLIENT_ID=(앱허브 자동 발급)
# OAUTH_CLIENT_SECRET=(앱허브 자동 발급)
